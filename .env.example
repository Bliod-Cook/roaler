ROALER_DATABASE_URL=postgres://roaler:roaler@postgres:5432/roaler
ROALER_REDIS_URL=redis://redis:6379
ROALER_BIND_ADDR=0.0.0.0:8080
ROALER_PUBLIC_BASE_URL=http://localhost:8080
ROALER_SESSION_COOKIE_NAME=roaler_session
ROALER_SESSION_SECRET=replace-with-a-long-random-string
ROALER_FILES_DIR=/var/lib/roaler/files
ROALER_DEFAULT_RSSHUB_BASE_URL=https://rsshub.app
ROALER_SYNC_INTERVAL_SECONDS=300

